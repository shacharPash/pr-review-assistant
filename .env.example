# Jira integration (optional).
# Copy this file to .env and fill in the values. `npm run dev` auto-loads it.

# Link-only mode: just this is enough to make ticket keys link to Jira.
JIRA_BASE_URL=https://your-org.atlassian.net

# Full mode: also fetches ticket title, status, description into the badge popover.
# Token is created at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=your-token-here
